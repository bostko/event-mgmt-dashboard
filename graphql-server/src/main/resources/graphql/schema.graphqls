type Query {
    mgmtEnvironmentById(id: ID): MgmtEnvironment
}

type MgmtService {
    id: ID!
    name: String
    owner: String
    environment: MgmtEnvironment!
}

type MgmtEnvironment {
    id: ID!
    name: String
    services: [MgmtService!]!
}

type MgmtEvent {
    id: ID!
    description: String
    timestamp: String
    service: MgmtService
}
